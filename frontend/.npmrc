# pnpm supply-chain attack 방어
# - 90일 (129,600분) 미만의 신규 publish 버전은 install 차단
# - npm/yarn 사용 금지, pnpm 만 사용
# - 룰 출처: docs 메모리 `feedback_pnpm_min_release_age`
minimum-release-age=129600

# 예외 — 이미 lockfile 에 잠긴 transitive 또는 신뢰 가능한 dev 도구.
# Next.js 자체 swc 플랫폼 패키지: lockfile 에 이미 lock 되어 추가 download 위험 없음.
# @playwright/test: e2e 자동 테스트용 dev tool, 정식 Microsoft 패키지.
minimum-release-age-exclude[]=@next/swc-*
minimum-release-age-exclude[]=@playwright/test
