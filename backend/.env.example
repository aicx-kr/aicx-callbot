# --- Server ---
HOST=0.0.0.0
PORT=8000
DATABASE_URL=sqlite:///./callbot.db

# --- Providers ---
# 사용 가능: "google" | "mock"
# 키가 없으면 자동으로 mock으로 fallback.
PROVIDER_STT=google
PROVIDER_TTS=google
PROVIDER_LLM=google
PROVIDER_VAD=silero

# --- Google Cloud ---
# 우선순위: GOOGLE_SERVICE_ACCOUNT_BASE64 > GOOGLE_APPLICATION_CREDENTIALS > ADC
# Base64 encoded service account JSON (chatbot-v2 호환). 권장.
# 생성: `base64 -i ~/.gcp/callbot-sa.json | tr -d '\n'`
GOOGLE_SERVICE_ACCOUNT_BASE64=
GOOGLE_APPLICATION_CREDENTIALS=
GOOGLE_CLOUD_PROJECT=callbot-493209
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# --- Speech ---
STT_LANGUAGE=ko-KR
STT_SAMPLE_RATE=16000
TTS_LANGUAGE=ko-KR
TTS_VOICE=ko-KR-Neural2-A
TTS_SAMPLE_RATE=16000

# --- VAD ---
VAD_SILENCE_MS=600
VAD_MIN_SPEECH_MS=200

# --- 마이리얼트립 도메인 API (시드 도구가 사용) ---
# 봇 환경변수 UI에서 봇별 격리 관리도 가능 — 여기는 fallback
MRT_CS_API_BASE=
API_TOKEN=
ZENDESK_API_BASE=
ZENDESK_AUTH=
